{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/img/(.*)", "dest": "/public/img/$1" },
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/js/(.*)", "dest": "/public/js/$1" },
    { "src": "/data/(.*)", "dest": "/public/minideptos/data/$1" },
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/panel", "dest": "/public/panel/index.html" },
    { "src": "/panel/(.*)", "dest": "/public/panel/$1" },
    { "src": "/projects", "dest": "/public/projects/index.html" },
    { "src": "/projects/(.*)", "dest": "/public/projects/$1" },
    { "src": "/(api|telegram-webhook|health)(.*)", "dest": "/api/index.js" },
    { "src": "/minideptos", "dest": "/public/minideptos/index.html" },
    { "src": "/minideptos/(.*)", "dest": "/public/minideptos/$1" },
    { "src": "/generar-planos", "dest": "/public/minideptos/generar-planos.html" },
    { "src": "/", "dest": "/public/minideptos/index.html" }
  ]
}
